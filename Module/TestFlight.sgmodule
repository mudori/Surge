#!name=TestFlight
#!desc=国区TF无法下载已下架APP解决方法
#!system=ios

[Script]
TestFlight = type=http-request,pattern=^https?:\/\/testflight\.apple\.com\/v2\/accounts\/.*\/apps\/\d*/builds/\d*/install,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/mudori/Surge/master/Script/TestFlight.js

[MITM]
hostname =  %APPEND% testflight.apple.com
