#!name=彩云天气
#!desc=个人版彩云token

[Script]
彩云天气VIP = type=http-response,pattern=https://biz.caiyunapp.com/v2/user\?app_name=weather,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/nzw9314/Surge/master/Script/caiyun.js
彩云天气 = type=cron, cronexp="0 6-23 * * *", type=http-request, pattern=https:\/\/((weather-data\.apple)|(api.weather))\.com, script-path=https://raw.githubusercontent.com/Peng-YM/QuanX/master/Tasks/caiyun.js, require-body=false
[MITM]
hostname=weather-data.apple.com, api.weather.com
