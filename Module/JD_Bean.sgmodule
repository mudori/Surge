#!name=京东京豆
#!desc=京豆类脚本
#!system=ios

[Script]
京东汽车兑换 = type=cron, cronexp="0 0 * * *", wake-system=1, timeout=2000, enable=true, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_car_exchange.js
京东种豆得豆 = type=cron, cronexp="10 7-21/2 * * *", wake-system=1, timeout=630, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_plantBean.js
京东宠汪汪 = type=cron, cronexp="15 */2 * * *", wake-system=1, timeout=320, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy.js
京东宠汪汪喂食 = type=cron, cronexp="12 */1 * * *", wake-system=1, timeout=30, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_feedPets.js
京东宠汪汪积分兑换奖品 = type=cron, cronexp="1 0,8,12,16 * * *", wake-system=1, timeout=30, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_reward.js
京东天天加速 = type=cron, cronexp="8 */3 * * *", wake-system=1, timeout=130, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_speed.js
京东摇钱树 = type=cron, cronexp="15 */5 * * *", wake-system=1, timeout=130, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_moneyTree.js
京东摇京豆 = type=cron, cronexp="5 0 * * *", wake-system=1, timeout=50, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_club_lottery.js
京东京小超 = type=cron, cronexp="11 1-23/5 * * *", wake-system=1, timeout=530, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_superMarket.js
京东京小超领蓝币兑换京豆 = type=cron, cronexp="0 0 * * *", wake-system=1, timeout=30, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_blueCoin.js
京东进店领豆 = type=cron, cronexp="10 0 * * *", wake-system=1, timeout=50, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_shop.js
京东全民开红包 = type=cron, cronexp="1 1 * * *", wake-system=1, timeout=150, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_redPacket.js
京豆变动通知 = type=cron, cronexp="0 7 * * *", wake-system=1, timeout=650, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bean_change.js
京东取关京东店铺商品 = type=cron, cronexp="30 6 * * *", wake-system=1, timeout=250, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_unsubscribe.js
京东汽车 = type=cron, cronexp="10 7 * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_car.js
京东直播红包雨 = type=cron, cronexp="0 0, 9, 11, 13, 15, 17, 19, 20, 21, 23 * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_live_redrain.js
京东健康抽奖机 = type=cron, cronexp="3 0 * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_health.js
京东领京豆额外奖励 = type=cron, cronexp="7 7 * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bean_home.js
京东京喜工厂 = type=cron, cronexp="10 * * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_dreamFactory.js
京东抽奖机 = type=cron, cronexp=5 0 * * *, wake-system=1, timeout=1200, script-path=https://raw.githubusercontent.com/yangtingxiao/QuantumultX/master/scripts/jd/jd_lotteryMachine.js, script-update-interval=0
京东赚赚 = type=cron, cronexp="0 0 * * *", wake-system=1, timeout=20, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_jdzz.js
# 京东注销店铺会员卡 = type=cron, cronexp="55 23 * * *", wake-system=1, timeout=620, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_unbind.js
京东口袋书店 = type=cron, cronexp="0 8, 12, 18 * * *", wake-system=1, timeout=1120, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bookshop.js
京东签到领现金 = type=cron, cronexp="0 2 * * *", wake-system=1, timeout=80, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_cash.js
京东京喜签到 = type=cron, cronexp="2 0 * * *", wake-system=1, timeout=100, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jx_sign.js
京东年货节 = type=cron, cronexp="0 7 * * *", wake-system=1, timeout=1600, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_nh.js
京东家庭号 = type=cron, cronexp="1 * * * *", wake-system=1, timeout=2250, script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_family.js

[MITM]
hostname = %APPEND% api.m.jd.com
