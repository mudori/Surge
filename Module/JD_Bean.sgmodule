# 京东注销店铺会员卡 = type=cron, cronexp="55 23 * * *", wake-system=1, timeout=620, script-path=https://raw.githubusercontent.com/Shineslee/rules/master/jd/jd_unbind.js
删除优惠券 = type=cron,cronexp="0 6 * * *",wake-system=1,timeout=3600,script-path=https://raw.githubusercontent.com/jiegangwu/jd2/master/jd_delCoupon.js
